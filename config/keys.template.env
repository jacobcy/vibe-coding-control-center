# Vibe Coding 配置模板
# 复制此文件为 keys.env 并填入你的值
# 注意：keys.env 包含敏感信息，千万不要提交到 Git！

# ================= Claude Code 配置 =================
# Claude Code 配置说明（三种使用场景）：
#
# 【场景 1】使用原生 Claude（最简单，推荐新手）
#   - 直接使用 Anthropic 官方 Claude Code
#   - ✅ 无需配置任何 ANTHROPIC 环境变量
#   - Claude Code 会自动处理认证
#
# 【场景 2】使用 cc-switch 工具（推荐进阶用户）
#   - cc-switch 会自动管理所有 Claude 配置和密钥切换
#   - ✅ 无需在此文件手动配置 ANTHROPIC 变量
#   - 配置由 cc-switch 统一管理，更安全便捷
#
# 【场景 3】使用第三方 Claude API（需要手动配置）
#   - 不想安装 cc-switch，想直接使用第三方 Claude API
#   - 推荐使用智谱 GLM 或阿里云 Qwen（国内访问更快）
#   - ⚠️ 需要配置以下所有环境变量
#
# ── 智谱 GLM 配置示例 ───────────────────────────────────────
# export ANTHROPIC_AUTH_TOKEN=<your-zhipu-token>
# export ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# export ANTHROPIC_MODEL=glm-5
# export ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5
# export ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.7
# export ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.1
# export ANTHROPIC_REASONING_MODEL=glm-5.1
#
# ── 阿里云 Qwen 配置示例 ───────────────────────────────────────
# export ANTHROPIC_AUTH_TOKEN=<your-qwen-token>
# export ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
# export ANTHROPIC_MODEL=glm-5
# export ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5
# export ANTHROPIC_DEFAULT_HAIKU_MODEL=qwen3.5-plus
# export ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5
# export ANTHROPIC_REASONING_MODEL=glm-5
#
# 如果使用场景 1 或 2，请删除或注释掉以下所有 ANTHROPIC 配置：
ANTHROPIC_AUTH_TOKEN=<your-token>
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_MODEL=glm-5
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.7
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.1
ANTHROPIC_REASONING_MODEL=glm-5.1
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
ENABLE_TOOL_SEARCH=true

# ================= GitHub 配置 =================
# GitHub Token - 用于访问 GitHub API（创建 PR、查看 issue 等）
#
# 【配置方式 1】使用 gh auth login（推荐，最简单）
#   运行命令：gh auth login
#   系统会自动配置 token，无需手动填写
#
# 【配置方式 2】手动配置 Token
#   如果不想用 gh auth login，可以手动创建 token：
#   1. 访问：https://github.com/settings/tokens
#   2. 点击 "Generate new token (classic)"
#   3. 选择权限：repo（读写仓库）、read:org（读取组织）
#   4. 复制生成的 token 粘贴到下面
#
GH_TOKEN=<your-github-token-here>

# Manager Bot Token - 用于 Manager Agent 的独立身份（可选）
# 如果配置，Manager Agent 将使用此 token 而非 GH_TOKEN
# 用途：区分人类和 Manager Bot 的 GitHub 操作，避免身份混淆
# 获取方式：与 GH_TOKEN 相同，但使用不同的 Bot 账号
VIBE_MANAGER_GITHUB_TOKEN=

# ================= AI 搜索配置 =================
# Exa Search API - AI 驱动的智能搜索引擎
# 用途：代码搜索、技术文档查询、替代传统搜索
# 特点：比 Google 更懂开发者需求，结果更精准
#
# 获取方式：
#   1. 访问：https://exa.ai
#   2. 注册账号（免费试用）
#   3. 获取 API Key
#
EXA_API_KEY=<your-exa-api-key-here>

# Context7 API - 实时文档检索服务
# 用途：获取最新技术文档（React、Next.js、Prisma 等）
# 特点：文档始终最新，避免查到过时信息
#
# 获取方式：
#   1. 访问：https://context7.com
#   2. 注册账号（免费试用）
#   3. 获取 API Key
#
CONTEXT7_API_KEY=<your-context7-api-key-here>

# ================= Claude Plugin 配置 =================
# OpenAI API Key - 用于 Codex Plugin（OpenAI 代码助手）
#
# 【配置方式 1】使用 OpenAI OAuth 登陆（推荐）
#   运行 Codex 时会自动 OAuth 认证
#   ✅ 无需配置此密钥
#
# 【配置方式 2】使用第三方 OpenAI API
#   如果使用 OpenAI 中转站或自己的 API key：
#   获取地址：https://platform.openai.com
#
# 第三方 OpenAI API 完整配置示例：
# export OPENAI_API_KEY=<your-openai-api-key-here>
# export OPENAI_BASE_URL=https://your-proxy.com/v1  # 中转站地址
# export OPENAI_MODEL=codex-auto                     # 模型名称（可选）
#
OPENAI_API_KEY=<your-openai-api-key-here>
OPENAI_BASE_URL=https://your-proxy.com/v1 
OPENAI_MODEL=codex-auto  

# ================= 其他 AI 后端（可选） =================
# DeepSeek API - DeepSeek AI 模型（国产，性价比高）
# 用途：AI 辅助文案生成（如 PR create --ai 自动生成 PR 描述）
# 特点：价格便宜，性能不错，适合预算有限的用户
#
# 💡 推荐替代方案：统一使用 Gemini（见下方）
#   - Gemini 既可以用于 AI 辅助文案，也可以用于 claude-mem 总结
#   - 一个 Key 解决两个用途，配置更简单
#
# 获取方式：
#   1. 访问：https://api.deepseek.com
#   2. 注册账号
#   3. 获取 API Key
#
DEEPSEEK_API_KEY=<your-deepseek-key-here>

# Google Gemini API - Google AI 模型（推荐统一使用）
# 用途：
#   1. AI 辅助文案生成（替代 DeepSeek）
#   2. claude-mem 总结功能（代码记忆和智能检索）
#
# 【配置方式 1】使用 Gemini OAuth 登陆（推荐）
#   如果你不用 claude-mem，可以只用 Gemini OAuth，无需配置 Key
#   运行 Gemini 相关命令时自动 OAuth 认证
#
# 【配置方式 2】手动配置 Gemini API Key
#   如果使用 claude-mem 或需要稳定调用 Gemini API：
#   获取地址：https://ai.google.dev
#
GEMINI_API_KEY=<your-google-api-key-here>

# ================= Vibe Agent 配置覆盖 =================
# 通过环境变量覆盖 config/models.json 中的 agent 配置
# 优先级：环境变量 > models.json > 默认值
#
# 【全局默认值】
# VIBE_DEFAULT_BACKEND=gemini          # 覆盖 default_backend
# VIBE_DEFAULT_MODEL=gemini-3-flash-preview  # 覆盖 default_model
#
# 【Agent 级别覆盖】
# 格式：VIBE_BACKEND_<ROLE> / VIBE_MODEL_<ROLE>
# Role 名称：vibe-manager → MANAGER（大写，去掉 vibe- 前缀）
#
# ── 配置示例 ───────────────────────────────────────────────
# 让 vibe-planner 使用 OpenAI Codex：
# export VIBE_BACKEND_PLANNER=codex
# export VIBE_MODEL_PLANNER=gpt-5.4
#
# 让 vibe-manager 使用 Claude：
# export VIBE_BACKEND_MANAGER=claude
# export VIBE_MODEL_MANAGER=sonnet
#
# 让 vibe-executor 使用 Gemini：
# export VIBE_BACKEND_EXECUTOR=gemini
# export VIBE_MODEL_EXECUTOR=gemini-3-flash-preview
#
# 当前配置（取消注释以启用）：
# VIBE_BACKEND_PLANNER=opencode
# VIBE_MODEL_PLANNER=deepseek/deepseek-v4-pro