#!/usr/bin/env zsh
# Vibe CLI - Basic utilities wrapper
# V3 commands: use `vibe3` or `uv run python src/vibe3/cli.py`

set -e

# ── Context ─────────────────────────────────────────────
VIBE_SCRIPT_PATH="${(%):-%x:A}"
VIBE_SCRIPT_DIR="$(cd "$(dirname "$VIBE_SCRIPT_PATH")" && pwd)"
VIBE_INSTALL_ROOT="$(cd "$VIBE_SCRIPT_DIR/.." && pwd)"

# If invoked through the global install (~/.vibe/bin/vibe), prefer the current repo's bin/vibe.
VIBE_REAL_INSTALL_ROOT="$(cd "$VIBE_INSTALL_ROOT" && pwd -P 2>/dev/null || echo "$VIBE_INSTALL_ROOT")"
VIBE_REAL_HOME_VIBE="$(cd "$HOME/.vibe" 2>/dev/null && pwd -P || echo "$HOME/.vibe")"

if [[ "$VIBE_REAL_INSTALL_ROOT" == "$VIBE_REAL_HOME_VIBE" ]] && command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    REPO_VIBE="${REPO_ROOT}/bin/vibe"
    if [[ -n "$REPO_ROOT" && -x "$REPO_VIBE" ]]; then
        exec "$REPO_VIBE" "$@"
    fi
fi

export VIBE_ROOT="$VIBE_INSTALL_ROOT"
source "$VIBE_ROOT/lib/config.sh"
readonly VIBE_VERSION="$(get_vibe_version)"

# ── Dispatcher ──────────────────────────────────────────
command="${1:-help}"
shift 2>/dev/null || true

case "$command" in
    doctor)
        source "$VIBE_LIB/doctor.sh"
        vibe_doctor "$@"
        ;;
    tools)
        source "$VIBE_LIB/tool.sh"
        vibe_tool "$@"
        ;;
    keys)
        source "$VIBE_LIB/keys.sh"
        vibe_keys "$@"
        ;;
    clean)
        source "$VIBE_LIB/clean.sh"
        vibe_clean "$@"
        ;;
    skills)
        source "$VIBE_LIB/skills.sh"
        vibe_skills "$@"
        ;;
    alias)
        source "$VIBE_LIB/alias.sh"
        vibe_alias "$@"
        ;;
    version|-v|--version)
        echo "Vibe $VIBE_VERSION"
        ;;
    help|--help|-h)
        echo "${BOLD}Vibe CLI${NC} v${VIBE_VERSION} (basic utilities)"
        echo ""
        echo "Usage: ${CYAN}vibe <command>${NC} [args]"
        echo ""
        echo "For flow/task/pr commands, use: ${GREEN}vibe3${NC}"
        echo ""
        echo "Utilities:"
        echo "  ${GREEN}doctor${NC}   环境诊断与依赖检查"
        echo "  ${GREEN}skills${NC}   Skills 物理同步与状态检查"
        echo "  ${GREEN}keys${NC}     API 密钥安全管理"
        echo "  ${GREEN}clean${NC}    清理项目临时/构建文件"
        echo "  ${GREEN}tools${NC}    AI 开发工具链安装/更新"
        echo "  ${GREEN}alias${NC}    加载 Shell 快捷别名"
        ;;
    flow|task|roadmap|check)
        echo "${YELLOW}⚠️  This command has moved to V3.${NC}"
        echo "Use: ${GREEN}vibe3 ${command} ${*}${NC}"
        exit 1
        ;;
    *)
        echo "Unknown command: $command"
        echo "Run 'vibe help' for usage."
        exit 1
        ;;
esac
