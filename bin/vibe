#!/usr/bin/env zsh
# v2/bin/vibe - CLI Entry Point for Vibe 2.0
# Target: ~50 lines | Dispatches to lib/ modules

set -e

# ── Context ─────────────────────────────────────────────
VIBE_SCRIPT_DIR="$(cd "$(dirname "${(%):-%x}")" && pwd)"
# Force local VIBE_ROOT if running from the source tree to avoid contamination
export VIBE_ROOT="$(cd "$VIBE_SCRIPT_DIR/.." && pwd)"

source "$VIBE_ROOT/lib/config.sh"

# ── Version ─────────────────────────────────────────────
readonly VIBE_VERSION="$(get_vibe_version)"

# ── Dispatcher ──────────────────────────────────────────
command="${1:-help}"
shift 2>/dev/null || true

case "$command" in
    doctor)
        source "$VIBE_LIB/doctor.sh"
        vibe_doctor "$@"
        ;;
    check)
        source "$VIBE_LIB/check.sh"
        vibe_check "$@"
        ;;
    tool)
        source "$VIBE_LIB/tool.sh"
        vibe_tool "$@"
        ;;
    keys)
        source "$VIBE_LIB/keys.sh"
        vibe_keys "$@"
        ;;
    flow)
        source "$VIBE_LIB/flow.sh"
        vibe_flow "$@"
        ;;
    task)
        source "$VIBE_LIB/task.sh"
        vibe_task "$@"
        ;;
    clean)
        source "$VIBE_LIB/clean.sh"
        vibe_clean "$@"
        ;;
    skills)
        source "$VIBE_LIB/skills.sh"
        vibe_skills "$@"
        ;;
    alias)
        source "$VIBE_LIB/alias.sh"
        vibe_alias "$@"
        ;;
    version|-v|--version)
        echo "Vibe $VIBE_VERSION"
        ;;
    help|--help|-h)
        echo "${BOLD}Vibe Coding Control Center${NC} v${VIBE_VERSION}"
        echo ""
        echo "Usage: ${CYAN}vibe <command>${NC} [args]"
        echo ""
        echo "Primary Commands:"
        echo "  ${GREEN}flow${NC}     开发环境编排（new, done, status, sync）"
        echo "  ${GREEN}task${NC}     任务生命周期管理（list, add, update, remove, sync）"
        echo "  ${GREEN}check${NC}    项目全要素审计与格式校验"
        echo ""
        echo "System Commands:"
        echo "  ${GREEN}doctor${NC}   环境诊断与依赖检查"
        echo "  ${GREEN}skills${NC}   Skills 物理同步与状态检查"
        echo "  ${GREEN}keys${NC}     API 密钥安全管理 (list, set, get, init)"
        echo "  ${GREEN}clean${NC}    清理项目临时/构建文件"
        echo ""
        echo "Utility Commands:"
        echo "  ${GREEN}tool${NC}     AI 开发工具链安装/更新"
        echo "  ${GREEN}alias${NC}    加载 Shell 快捷别名"
        echo "  ${GREEN}version${NC}  显示当前版本号"
        echo ""
        echo "💡 提示：在 AI 助手环境，优先使用 /vibe-new 开启新功能开发。"
        ;;
    *)
        echo "${BOLD}Vibe Coding Control Center${NC} v${VIBE_VERSION}"
        echo ""
        echo "Usage: ${CYAN}vibe <command>${NC} [args]"
        echo "Unknown command: $command"
        exit 1
        ;;
esac
