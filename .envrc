# Vibe Center - per-worktree env (committed, non-secret)
export UV_PROJECT_ENVIRONMENT="$HOME/.venvs/vibe-center"   # Shared venv (deps only)
export PYTHONPATH="$PWD/src${PYTHONPATH:+:$PYTHONPATH}"     # Resolve to local worktree src/
source_env_if_exists .envrc.local                          # Optional local overrides (gitignored)
